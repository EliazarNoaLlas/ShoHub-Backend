{
	"name": "back-end",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"scripts": {
		"postinstall": "prisma generate",
		"start": "node dist/server.js",
		"build": "tsc -p tsconfig.build.json",
		"dev": "ts-node-dev --respawn --transpile-only src/server.ts",
		"test": "cross-env NODE_ENV=test jest",
		"test:unit": "cross-env NODE_ENV=test jest --testPathPattern=unit --coverage --coverageDirectory=coverage/unit",
		"test:integration": "cross-env NODE_ENV=test jest --testPathPattern=integration --coverage --coverageDirectory=coverage/integration",
		"test:e2e": "cross-env NODE_ENV=test jest --testPathPattern=e2e --coverage --coverageDirectory=coverage/e2e",
		"test:all": "cross-env NODE_ENV=test jest --coverage",
		"test:watch": "cross-env NODE_ENV=test jest --watch",
		"test:coverage": "cross-env NODE_ENV=test jest --coverage",
		"test:ci": "cross-env NODE_ENV=test jest --ci --coverage --forceExit"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@prisma/client": "6.19.0",
		"bcrypt": "^5.1.1",
		"body-parser": "^2.2.2",
		"cloudinary": "^2.2.0",
		"cors": "^2.8.5",
		"dotenv": "^16.4.5",
		"express": "^5.2.1",
		"jsonwebtoken": "^9.0.2",
		"lodash": "^4.18.1",
		"mongoose": "^9.4.1",
		"nodemailer": "^8.0.5",
		"slugify": "^1.6.6",
		"stripe": "^16.8.0",
		"ts-node-dev": "^2.0.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/bcrypt": "^5.0.2",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/jest": "^29.5.14",
		"@types/jsonwebtoken": "^9.0.6",
		"@types/multer": "^1.4.11",
		"@types/node": "^20.12.11",
		"@types/nodemailer": "^6.4.17",
		"@types/supertest": "^6.0.3",
		"cross-env": "^7.0.3",
		"jest": "^29.7.0",
		"prisma": "6.19.0",
		"supertest": "^7.1.1",
		"ts-jest": "^29.3.2",
		"typescript": "^5.4.5"
	}
}
