@baseUrl = http://localhost:5000/api/v1
@contentType = application/json

@ts = {{$timestamp}}

###
# @name Featured_CreateProduct_201
POST {{baseUrl}}/product/
Content-Type: {{contentType}}

{
  "name": "HTTP Featured Product {{ts}}",
  "description": "Product for featured-product tests",
  "price": 700,
  "regularPrice": 800,
  "inStock": 3,
  "photo": "https://example.com/featured-product-{{ts}}.png",
  "brand": "BrandF",
  "processor_type": "Intel",
  "processor_model": "i7",
  "generation": "13th",
  "display": "QHD",
  "display_size": "16",
  "display_type": "IPS",
  "ram": "16GB",
  "ram_type": "DDR5",
  "hdd": "0",
  "ssd": "1TB",
  "graphics": "RTX 4050",
  "operating_system": "Windows 11",
  "features": ["wifi", "bt"]
}

> {%
  client.test("create product: 201", () => client.assert(response.status === 201));
  client.global.set("productId", response.body.result.id);
%}

