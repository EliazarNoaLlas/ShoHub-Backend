# @name Featured_Create_201
POST {{baseUrl}}/featured-product/
Content-Type: {{contentType}}

{
  "productId": "{{productId}}"
}

> {%
  client.test("create featured product: 201", () => client.assert(response.status === 201));
  client.global.set("featuredId", response.body.result.id);
%}

