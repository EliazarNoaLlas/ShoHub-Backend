# @name HotOffers_GetAll_200
GET {{baseUrl}}/hot-offer/

> {%
  client.test("list hot offers: 200", () => client.assert(response.status === 200));
%}

###
# @name HotOffers_GetById_200
GET {{baseUrl}}/hot-offer/{{hotOfferId}}

> {%
  client.test("get hot offer by id: 200", () => client.assert(response.status === 200));
%}

###
# @name HotOffers_Update_201
PATCH {{baseUrl}}/hot-offer/{{hotOfferId}}
Content-Type: {{contentType}}

{
  "discount": 12
}

> {%
  client.test("update hot offer: 201 (controller uses 201)", () => client.assert(response.status === 201));
%}

###
# @name HotOffers_Delete_201
DELETE {{baseUrl}}/hot-offer/{{hotOfferId}}

> {%
  client.test("delete hot offer: 201 (controller uses 201)", () => client.assert(response.status === 201));
%}

