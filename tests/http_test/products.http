###
# @name Products_Update_401_NoAuth
PATCH {{baseUrl}}/product/{{productId}}
Content-Type: {{contentType}}

{
  "price": 950
}

> {%
  client.test("update product without auth: 401", () => client.assert(response.status === 401));
%}

###
# Nota: el controller pasa `slug` pero el service actualiza por `id` (bug).
# Caso 1: usando el slug real suele dar 404.
# @name Products_Update_BySlug_404
PATCH {{baseUrl}}/product/{{productSlug}}
Content-Type: {{contentType}}
Authorization: {{adminToken}}

{
  "price": 950
}

> {%
  client.test("update by slug (bug): 404", () => client.assert(response.status === 404));
%}

###
# Caso 2: pasando el id en el param ":slug" funciona.
# @name Products_Update_ById_200
PATCH {{baseUrl}}/product/{{productId}}
Content-Type: {{contentType}}
Authorization: {{adminToken}}

{
  "price": 950
}

> {%
  client.test("update by id: 200", () => client.assert(response.status === 200));
%}

###
# @name Products_SoftDelete_200
DELETE {{baseUrl}}/product/soft/{{productId}}
Authorization: {{adminToken}}

> {%
  client.test("soft delete: 200", () => client.assert(response.status === 200));
%}

###
# Delete definitivo (mismo bug que update: endpoint dice ":slug" pero usa id en el service)
# @name Products_Delete_BySlug_404
DELETE {{baseUrl}}/product/{{productSlug}}
Authorization: {{adminToken}}

> {%
  client.test("delete by slug (bug): 404", () => client.assert(response.status === 404));
%}

###
# @name Products_Delete_ById_200
DELETE {{baseUrl}}/product/{{productId}}
Authorization: {{adminToken}}

> {%
  client.test("delete by id: 200", () => client.assert(response.status === 200));
%}

