# Test environment variables (use a dedicated database)
#
# IMPORTANT:
# - Use a separate MongoDB database for tests to avoid deleting real data.
# - For local tests you can point to a local MongoDB instance.

PORT=5001
NODE_ENV=test

# Prisma (MongoDB)
DATABASE_URL="mongodb://localhost:27017/gadget-galaxy-test"

SALT_ROUND=12
JWT_SECTET="test-jwt-secret"
JWT_EXPIRES="1d"

STRIPE_API_KEY="sk_test_your_key"
DOMAIN_URL="http://localhost:3000"

EMAIL="test@example.com"
PASSWORD="test-password"

CLOUD_NAME="test-cloud"
API_KEY="test-api-key"
API_SECRET="test-api-secret"

